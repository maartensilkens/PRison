{
  "name": "prison",
  "displayName": "PRison",
  "description": "Your PRs are in prison. Only YOU can set them free. 🔒",
  "version": "1.0.0",
  "publisher": "MaartenSilkens",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0d0d0d",
    "theme": "dark"
  },
  "keywords": [
    "github",
    "pull request",
    "code review",
    "shame",
    "meme"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/prison-dev/prison"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "prison.showOverlay",
        "title": "PRison: Show Shame Overlay"
      },
      {
        "command": "prison.checkPRs",
        "title": "PRison: Check PRs Now"
      },
      {
        "command": "prison.clearCache",
        "title": "PRison: Clear Cache"
      },
      {
        "command": "prison.openPR",
        "title": "Open PR in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "prison.demo",
        "title": "PRison: Demo Overlay (no GitHub needed)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prison-sidebar",
          "title": "PRison",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "prison-sidebar": [
        {
          "type": "webview",
          "id": "prison.sidebar",
          "name": "PRison"
        }
      ]
    },
    "configuration": {
      "title": "PRison",
      "properties": {
        "prison.repos": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "GitHub repos to monitor (e.g. ['org/repo1', 'org/repo2']). Leave empty to auto-detect from git remote."
        },
        "prison.pollingInterval": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "How often to check GitHub for PR updates (minutes)"
        },
        "prison.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Disable all shame overlays and terminal blocking. The sidebar still works."
        },
        "prison.overlayOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Show shame overlay when VS Code starts (if you have PR debt)"
        },
        "prison.overlayOnBranchChange": {
          "type": "boolean",
          "default": true,
          "description": "Show shame overlay when checking out or creating a branch"
        },
        "prison.soundEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Play a meme sound effect when the shame overlay appears 🔊"
        },
        "prison.blockTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Show shame overlay every time you open a terminal while you have 2+ PRs needing attention 💀"
        },
        "prison.requiredApprovals": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "Number of approvals required before a PR is considered 'done' ✅"
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production && vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^8.56.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
